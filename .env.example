# LegacyLens Environment Variables

# Required API Keys
OPENAI_API_KEY=sk-your-openai-key-here

# Database
DATABASE_URL=postgresql+asyncpg://legacylens:dev@localhost:5432/legacylens

# Optional: Logging level
LOG_LEVEL=INFO

# Optional: Embedding model
EMBEDDING_MODEL=text-embedding-3-small

# Optional: Answer model
ANSWER_MODEL=gpt-4o
